# PANACEA ICONO Environment Configuration Example
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORGANIZATION=your_organization_id_here

# Hugging Face Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_EMAIL=your_email@example.com

# Heroku Configuration
HEROKU_API_KEY=your_heroku_api_key_here
HEROKU_APP_NAME=your-app-name
PRODUCTION_URL=https://your-app.herokuapp.com
STAGING_URL=https://your-app-staging.herokuapp.com

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_EMAIL=your_email@example.com
GITHUB_USERNAME=your_username
GITHUB_REPO=username/repository-name

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# External Services
PAYMENT_SERVICE_URL=https://payment-service.com
NOTIFICATION_SERVICE_URL=https://notification-service.com

# Monitoring
LOG_LEVEL=INFO
ENVIRONMENT=development
